<div class="task-item" onclick="@Redirect">
    <article class="sticky-note">
        <div class="sticky-tape" aria-hidden="true"></div>

        <header class="sticky-header">
            <span class="note-id">#@TaskId.ToString("D4")</span>
            <div class="header-dates">
                @if (StartDate is not null)
                {
                    <small class="start-date">Start: @StartDate?.ToString("d")</small>
                }
            </div>
        </header>

        <h2 class="note-title">@Title</h2>

        <p class="note-desc">@Description</p>

        <div class="note-meta">
            <div>Assigned to: <strong>@UserName</strong></div>
            <div>Issuer: <strong>@IssuerName</strong></div>
        </div>

        <div class="note-footer">
            <div class="status-block">
                @if (Status == 0)
                {
                    <span class="status-badge pending">Pending</span>
                }
                else if (Status == 1)
                {
                    <span class="status-badge inprogress">In Progress</span>
                }
                else if (Status == 2)
                {
                    <span class="status-badge completed">Completed</span>
                }
                else if (Status == 3)
                {
                    <span class="status-badge cancelled">Cancelled</span>
                }
            </div>
            <small class="timestamps">Created: @CreatedAt?.ToString("d") <br/> @if (DueDate is not null) { <text> Due: @DueDate?.ToString("d")</text> }</small>
        </div>
    </article>
</div>
