@page "/new-task"

@rendermode InteractiveServer

<PageTitle>New Task</PageTitle>

<div class="task-page">
    <div class="task-form-card">
        <div class="task-form-header">
            <h1 class="task-form-title">Create New Task</h1>
            <p class="task-form-subtitle">Fill in the details below to add a new task.</p>
        </div>

        <EditForm Model="@_newTaskFormModel" OnValidSubmit="@AddTask" class="task-form">
            <DataAnnotationsValidator/>

            <div class="task-form-group">
                <label class="form-label task-label">Title</label>
                <InputText @bind-Value="_newTaskFormModel.Title" class="form-control task-input" placeholder="Enter task title"/>
                <ValidationMessage For="@(() => _newTaskFormModel.Title)"/>
            </div>

            <div class="task-form-group">
                <label class="form-label task-label">Description</label>
                <InputTextArea @bind-Value="_newTaskFormModel.Description" class="form-control task-input" rows="5" placeholder="Write a short description"/>
                <ValidationMessage For="@(() => _newTaskFormModel.Description)"/>
            </div>

            <div class="task-form-row">
                <div class="task-form-group">
                    <label class="form-label task-label">Due Date</label>
                    <InputDate @bind-Value="_newTaskFormModel.DueDate" class="form-control task-input"/>
                    <ValidationMessage For="@(() => _newTaskFormModel.DueDate)"/>
                </div>

                <div class="task-form-group">
                    <label class="form-label task-label">Status</label>
                    <InputSelect @bind-Value="_newTaskFormModel.Status" class="form-select task-input">
                        <option value="0">Pending</option>
                        <option value="1">In Progress</option>
                        <option value="2">Completed</option>
                        <option value="3">Delivered</option>
                    </InputSelect>
                </div>
            </div>

            <button type="submit" class="btn btn-primary task-submit-btn">
                Add Task
            </button>
        </EditForm>
    </div>
</div>