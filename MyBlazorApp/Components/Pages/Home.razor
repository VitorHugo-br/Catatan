@page "/home"

<PageTitle>Catatan - Home</PageTitle>

<section class="hero">
    <div class="hero-inner">
        <div class="hero-content">
            <h1 class="hero-title">Organize your tasks.<br/> Capture your ideas.</h1>
            <p class="subtitle">Fast, simple and beautiful notes and task manager for your day-to-day.</p>

            <div class="hero-ctas">
                <NavLink class="btn btn-primary" href="/register">Get Started</NavLink>
                <NavLink class="btn btn-outline-secondary" href="/notes">View Notes</NavLink>
            </div>
        </div>

        <div class="cards-preview" aria-hidden="true">
            <article class="card card-1">
                <h3>Grocery list</h3>
                <p>Buy milk, eggs and coffee.</p>
            </article>

            <article class="card card-2">
                <h3>Project plan</h3>
                <p>Outline milestones and deadlines.</p>
            </article>

            <article class="card card-3">
                <h3>Ideas</h3>
                <p>Capture spontaneous ideas quickly.</p>
            </article>
        </div>
    </div>
</section>

<section class="features">
    <div class="feature">
        <h4>Quick notes</h4>
        <p>Save notes instantly with a clean editor.</p>
    </div>
    <div class="feature">
        <h4>Sync &amp; Secure</h4>
        <p>Sync across devices and keep your data safe.</p>
    </div>
    <div class="feature">
        <h4>Organize</h4>
        <p>Labels, priorities and reminders to stay on track.</p>
    </div>
</section>
