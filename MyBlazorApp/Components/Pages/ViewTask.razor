@page "/viewtask/{TaskId:int}"
@rendermode InteractiveServer   

<PageTitle>
    @MyTask?.Title
</PageTitle>

<div class="giant-sticky-wrap d-flex flex-column gap-2">
    <article class="giant-sticky " role="article" aria-label="Note detail">
        <div class="sticky-tape" aria-hidden="true"></div>

        <header class="gs-header">
            <strong class="gs-id">#@MyTask?.Id.ToString("D4")</strong>
            <div class="gs-actions">
                <button class="btn btn-sm btn-warning">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pen"
                         viewBox="0 0 16 16">
                        <path
                            d="m13.498.795.149-.149a1.207 1.207 0 1 1 1.707 1.708l-.149.148a1.5 1.5 0 0 1-.059 2.059L4.854 14.854a.5.5 0 0 1-.233.131l-4 1a.5.5 0 0 1-.606-.606l1-4a.5.5 0 0 1 .131-.232l9.642-9.642a.5.5 0 0 0-.642.056L6.854 4.854a.5.5 0 1 1-.708-.708L9.44.854A1.5 1.5 0 0 1 11.5.796a1.5 1.5 0 0 1 1.998-.001m-.644.766a.5.5 0 0 0-.707 0L1.95 11.756l-.764 3.057 3.057-.764L14.44 3.854a.5.5 0 0 0 0-.708z"/>
                    </svg>
                </button>
                <button class="btn btn-sm btn-danger">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                         class="bi bi-trash" viewBox="0 0 16 16">
                        <path
                            d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                        <path
                            d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                    </svg>
                </button>
                <NavLink class="btn btn-sm btn-outline-secondary" href="/notes">Back</NavLink>
            </div>
        </header>

        <h1 class="gs-title">@MyTask?.Title</h1>

        <section class="gs-body">
            <p class="gs-desc">@MyTask?.Description</p>
            <p class="gs-desc">assigned to: <strong>@Users.FirstOrDefault(x => x.Id == MyTask?.UserId)?.Name</strong>
            </p>
            <p class="gs-desc">issued by: <strong>@Issuers.FirstOrDefault(x => x.Id == MyTask?.IssuerId)?.Name</strong>
            </p>
            <p class="gs-desc">Due date: <strong>@MyTask?.DueDate?.ToString("d")</strong></p>
            <p class="gs-desc">Start date: <strong>@MyTask?.StartDate?.ToString("d")</strong></p>

            @switch (MyTask?.Status)
            {
                case 0:
                    <p class="gs-desc">Status: <span class="badge bg-secondary">Pending</span></p>
                    break;
                case 1:
                    <p class="gs-desc">Status: <span class="badge bg-primary">In Progress</span></p>
                    break;
                case 2:
                    <p class="gs-desc">Status: <span class="badge bg-success">Completed</span></p>
                    break;
                case 3:
                    <p class="gs-desc">Status: <span class="badge bg-danger">Cancelled</span></p>
                    break;
                default:
                    <p class="gs-desc">Status: <span class="badge bg-light text-dark">Unknown</span></p>
                    break;
            }
        </section>

        <footer class="gs-footer">
            <small class="gs-id-note">ID: #@MyTask?.Id.ToString("D4")</small>
        </footer>
    </article>

    @if (Comments.Any())
    {
        @foreach (var comment in Comments)
        {
            var issuerName = Users.FirstOrDefault(u => u.Id == comment.IssuerId)?.Name ?? "Unknown";
            var issuerInitial = !string.IsNullOrWhiteSpace(issuerName) ? issuerName.Trim()[0].ToString().ToUpperInvariant() : "?";

            <CommentComponent 
                IssuerInitial="@issuerInitial" 
                IssuerName="@issuerName" 
                CreatedAt="@comment.CreatedAt"
                Content="@comment.Content"
                CommentId="@comment.CommentId"
                CommentCallback="Rerender"
                />
        }
    }
    else
    {
        <section class="comment_empty">
            <small class="text-muted">No comments yet.</small>
        </section>
    }
</div>